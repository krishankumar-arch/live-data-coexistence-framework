# ═══════════════════════════════════════════════════════════════
# LDCF POC — deploy.env.example
# Author: Krishan Kumar | ORCID: 0009-0009-7302-7566
#
# USAGE:
#   1. Copy this file:   cp deploy.env.example deploy.env
#   2. Fill in values below
#   3. Run:              ./deploy.sh
#
# SECURITY:
#   deploy.env is in .gitignore — NEVER commit it.
#   deploy.env.example IS committed (has no real values).
#
# PASSWORD RULES:
#   - Minimum 8 characters
#   - Use letters, numbers, and these special chars: ! # % ^ & * - _ + =
#   - AVOID: @ / " \ ' ` space  (break shell quoting or RDS validation)
#   - DB_PASSWORD and DMS_PASSWORD must be DIFFERENT
# ═══════════════════════════════════════════════════════════════

# ── Database admin password ───────────────────────────────────
# Used for both RDS MySQL admin (ldcfadmin) and Aurora admin (ldcfadmin).
# Stored in Secrets Manager — never hardcoded in Lambda code.
DB_PASSWORD=ChangeMe#2024!

# ── DMS replication user password ────────────────────────────
# Used for ldcf_dms_user on MySQL — the dedicated CDC replication account.
# Must be different from DB_PASSWORD.
DMS_PASSWORD=DmsRepl#2024!

# ── SNS alert email ───────────────────────────────────────────
# Receives reconciliation failure alerts.
# AWS will send a confirmation email — click the link to activate.
ALERT_EMAIL=ops@example.com
